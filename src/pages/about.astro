---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About" description="Learn about Tech Hub — the tech community at UTech Jamaica. Who we are, what we do, and why we exist.">

  <section class="section">
    <div class="container">
      <span class="section-label">Our story</span>
      <h1 class="about-headline">We exist to close the gap<br/>between class and career.</h1>
      <p class="about-intro">Tech Hub was founded at the University of Technology, Jamaica by students who felt the gap between what was taught in the classroom and what the tech industry actually needed. We built the community we wished had existed when we started.</p>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container mission-grid">
      <div class="mission-text">
        <span class="section-label">Mission</span>
        <h2>Harness. Unite. Build.</h2>
        <p>Three words. One direction. Everything Tech Hub does maps back to these pillars — whether it's a workshop, a hackathon, or a casual study session.</p>
        <p style="margin-top:var(--space-4)">We are officially affiliated with the University of Technology, Jamaica and operate with the support of the Faculty of Engineering and Computing.</p>
      </div>
      <div class="mission-values">
        <div class="value card">
          <span class="value-num">01</span>
          <h3>Community first</h3>
          <p>No gatekeeping. Every student — regardless of skill level — is welcome at Tech Hub.</p>
        </div>
        <div class="value card">
          <span class="value-num">02</span>
          <h3>Ship real things</h3>
          <p>We don't just talk about building. We build. Every term, members ship something real.</p>
        </div>
        <div class="value card">
          <span class="value-num">03</span>
          <h3>Industry connected</h3>
          <p>Our mentors and speakers come from real companies. We bridge the campus-to-career gap.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <span class="section-label">The team</span>
      <h2>Led by students, for students.</h2>
      <div class="team-grid">
        {[
          { name: 'Team Member', role: 'President', bio: 'Add your team bios here.' },
          { name: 'Team Member', role: 'Vice President', bio: 'Add your team bios here.' },
          { name: 'Team Member', role: 'Technical Lead', bio: 'Add your team bios here.' },
          { name: 'Team Member', role: 'Events Lead', bio: 'Add your team bios here.' },
        ].map(m => (
          <div class="team-card card">
            <div class="team-avatar"></div>
            <h3>{m.name}</h3>
            <span class="team-role">{m.role}</span>
            <p>{m.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.about-headline { margin: var(--space-4) 0 var(--space-6); max-width: 18ch; }
.about-intro { font-size: var(--text-lg); max-width: 58ch; }
.mission-grid { display:grid; grid-template-columns:1fr 1fr; gap:var(--space-16); align-items:start; }
.mission-text h2 { margin: var(--space-4) 0 var(--space-6); }
.mission-text p { max-width: 44ch; }
.mission-values { display:flex; flex-direction:column; gap:var(--space-4); }
.value { display:flex; flex-direction:column; gap:var(--space-2); }
.value-num { font-family:var(--font-display); font-size:var(--text-xs); font-weight:700; letter-spacing:.1em; color:var(--color-primary); }
.value h3 { font-size:var(--text-lg); }
.team-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--space-6); margin-top:var(--space-8); }
.team-card { display:flex; flex-direction:column; gap:var(--space-2); align-items:center; text-align:center; }
.team-avatar { width:80px; height:80px; border-radius:50%; background:var(--color-surface-2); border:2px solid var(--color-border); margin-bottom:var(--space-2); }
.team-role { font-size:var(--text-xs); font-family:var(--font-display); font-weight:600; letter-spacing:.05em; text-transform:uppercase; color:var(--color-primary); }
.team-card p { font-size:var(--text-sm); text-align:center; }

@media (max-width:768px) {
  .mission-grid { grid-template-columns:1fr; }
  .team-grid { grid-template-columns:repeat(2,1fr); }
}
</style>
